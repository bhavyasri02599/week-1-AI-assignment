import requests

# Free Cat Facts API
url = "https://catfact.ninja/fact"

try:
    response = requests.get(url)
    response.raise_for_status()

    data = response.json()

    print("\n===== API RESPONSE =====")
    print("Cat Fact :", data["fact"])
    print("Length   :", data["length"])
    print("========================")

except requests.exceptions.RequestException as e:
    print("Error:", e)